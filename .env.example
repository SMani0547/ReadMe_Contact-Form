# Gmail account used to send contact-form messages.
GMAIL_USER=your-email@gmail.com

# Google-generated 16-character App Password.
# Paste it without spaces. Never use your normal Gmail password.
GMAIL_APP_PASSWORD=abcdefghijklmnop

# Inbox that should receive form submissions.
# This can be the same address as GMAIL_USER.
CONTACT_TO=your-email@gmail.com
